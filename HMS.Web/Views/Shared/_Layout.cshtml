@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - HMS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <style>
        
           /* Chatbot Button */

#chatbot-button{
position:fixed;
bottom:110px;   /* footer se upar */
right:25px;
background:linear-gradient(135deg,#1e3c72,#2a5298);
color:white;
width:60px;
height:60px;
border-radius:50%;
display:flex;
align-items:center;
justify-content:center;
cursor:pointer;
box-shadow:0 5px 20px rgba(0,0,0,.3);
z-index:9999;
}


/* Chat Window */

#chatbot{
position:fixed;
bottom:180px;   /* footer + button se upar */
right:25px;
width:340px;
background:white;
border-radius:12px;
display:none;
box-shadow:0 15px 40px rgba(0,0,0,.3);
z-index:9999;
}
            .chat-header {
                background: #2a5298;
                color: white;
                padding: 10px;
                border-radius: 10px 10px 0 0;
                display: flex;
                justify-content: space-between;
            }

            #chat-body {
                height: 300px;
                overflow-y: auto;
                padding: 10px;
            }

            .bot-msg {
                background: #f1f1f1;
                padding: 8px;
                margin: 5px;
                border-radius: 8px;
            }

            .user-msg {
                background: #2a5298;
                color: white;
                padding: 8px;
                margin: 5px;
                border-radius: 8px;
                text-align: right;
            }

            .chat-input {
                display: flex;
                border-top: 1px solid #ddd;
            }

                .chat-input input {
                    flex: 1;
                    border: none;
                    padding: 10px;
                }

                .chat-input button {
                    background: #2a5298;
                    color: white;
                    border: none;
                    padding: 10px;
                }

            body {
                overflow-x: hidden;
                background: #f5f7fb;
            }

            /* Sidebar */

            .sidebar {
                height: 100vh;
                background: linear-gradient(180deg,#1e3c72,#2a5298);
                color: white;
            }

                .sidebar a {
                    color: white;
                    padding: 12px 20px;
                    display: block;
                    text-decoration: none;
                }

                    .sidebar a:hover {
                        background: rgba(255,255,255,0.15);
                        border-radius: 5px;
                    }

            .logo {
                font-size: 20px;
                font-weight: 600;
            }

            /* Dark Mode */

            body.dark {
                background: #121212;
                color: white;
            }

                body.dark .sidebar {
                    background: #1a1a1a !important;
                }

                body.dark .navbar,
                body.dark footer {
                    background: #1e1e1e !important;
                    color: white;
                }

                body.dark .card {
                    background: #1e1e1e;
                    color: white;
                }

                body.dark .table {
                    color: white;
                }

                body.dark .form-control,
                body.dark .form-select {
                    background: #2a2a2a;
                    color: white;
                    border: 1px solid #444;
                }

    </style>

</head>

<body>

    <div class="container-fluid">
        <div class="row">

            <!-- Sidebar -->

            <div class="col-md-2 sidebar p-0">

                <div class="text-center p-3 border-bottom">
                    <h4>
                        <i class="fa fa-hospital"></i> HMS
                    </h4>
                </div>

                <ul class="nav flex-column">

                    <li>
                        <a asp-controller="Home" asp-action="Index">
                            <i class="fa fa-chart-line"></i> Dashboard
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Patients" asp-action="Index">
                            <i class="fa fa-user"></i> Patients
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Doctors" asp-action="Index">
                            <i class="fa fa-user-md"></i> Doctors
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Appointments" asp-action="Index">
                            <i class="fa fa-calendar"></i> Appointments
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Departments" asp-action="Index">
                            <i class="fa fa-building"></i> Departments
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Billing" asp-action="Index">
                            <i class="fa fa-file-invoice"></i> Billing
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Reports" asp-action="Patients">
                            <i class="fa fa-chart-bar"></i> Reports
                        </a>
                    </li>

                </ul>

            </div>


            <!-- Main -->

            <div class="col-md-10 p-0 d-flex flex-column min-vh-100">

                <!-- Navbar -->

                <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">

                    <div class="container-fluid">

                        <span class="logo">
                            Hospital Management System
                        </span>

                        <div class="ms-auto d-flex align-items-center">

                            <button class="btn btn-sm btn-outline-dark me-3"
                                    onclick="toggleTheme()">
                                <i class="fa fa-moon"></i>
                            </button>

                            @if (HttpContextAccessor.HttpContext.Session.GetString("JWT") == null)
                            {
                                <a class="btn btn-outline-primary me-2"
                                       asp-controller="Account"
                                       asp-action="Login">
                                    Login
                                </a>

                                <a class="btn btn-primary"
                                       asp-controller="Account"
                                       asp-action="Register">
                                    Register
                                </a>
                            }
                            else
                            {
                                <div class="dropdown">

                                    <button class="btn btn-light dropdown-toggle"
                                            data-bs-toggle="dropdown">

                                        @HttpContextAccessor.HttpContext.Session.GetString("UserName")

                                    </button>

                                    <ul class="dropdown-menu dropdown-menu-end">

                                        <li>
                                            <a class="dropdown-item"
                                                   asp-controller="Account"
                                                   asp-action="Logout">
                                                Logout
                                            </a>
                                        </li>

                                    </ul>

                                </div>
                            }

                        </div>

                    </div>

                </nav>
                <!-- Chatbot Button -->

                <div id="chatbot-button" onclick="toggleChat()">
                    <i class="fa fa-comments"></i>
                </div>


                <!-- Chatbot Window -->

                <div id="chatbot">

                    <div class="chat-header">

                        Hospital Assistant

                        <span onclick="toggleChat()">✖</span>

                    </div>

                    <div id="chat-body">

                        <div class="bot-msg">
                            Hello 👋
                            How can I help you?
                        </div>

                    </div>

                    <div class="chat-input">

                        <input type="text"
                               id="chat-input"
                               placeholder="Type message..."
                               onkeypress="handleKey(event)">

                        <button onclick="sendMessage()">
                            Send
                        </button>

                    </div>

                </div>
              <script>

function toggleChat(){
var chat=document.getElementById("chatbot");

if(chat.style.display==="block")
chat.style.display="none";
else
chat.style.display="block";
}

function handleKey(e){
if(e.key==="Enter"){
sendMessage();
}
}

async function sendMessage(){

var input=document.getElementById("chat-input");
var message=input.value;

if(message.trim()==="") return;

var body=document.getElementById("chat-body");

body.innerHTML +=
'<div class="user-msg">'+message+'</div>';

input.value="";

try{

const response = await fetch(
"https://localhost:44382/Api/AI/ask",
{
method:"POST",
headers:{
"Content-Type":"application/json"
},
body:JSON.stringify(message)
});

const data = await response.json();

const reply =
JSON.parse(data)
.candidates[0]
.content.parts[0]
.text;

body.innerHTML +=
'<div class="bot-msg">'+reply+'</div>';

body.scrollTop = body.scrollHeight;

}
catch{

body.innerHTML +=
'<div class="bot-msg">AI Server Error</div>';

}

}

</script>
                <!-- Body -->

                <div class="container-fluid mt-3 flex-grow-1">

                    <main role="main">
                        @RenderBody()
                    </main>

                </div>


                <!-- Footer -->

                <footer class="bg-white border-top p-3 mt-auto">

                    <div class="d-flex justify-content-between">

                        <span>
                            Hospital Management System © @DateTime.Now.Year
                        </span>

                        <span>
                            Version 1.0
                        </span>

                    </div>

                </footer>

            </div>

        </div>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>

            function toggleTheme(){

            document.body.classList.toggle("dark");

            localStorage.setItem("theme",
            document.body.classList.contains("dark")
            ? "dark" : "light");

            }

            window.onload = function(){

            if(localStorage.getItem("theme")==="dark"){
            document.body.classList.add("dark");
            }

            }

    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>